# TRU-NEXUS Configuration

# Mode: paper | live
TRADING_MODE=paper

# Claude API (for daily strategy review)
ANTHROPIC_API_KEY=sk-ant-xxx

# Ollama (local LLM for regime/signal)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:7b

# TradeLocker API
TRADELOCKER_API_URL=https://api.tradelocker.com
TRADELOCKER_API_KEY=
TRADELOCKER_ACCOUNT_ID=

# Dashboard
DASHBOARD_PORT=3456
DASHBOARD_SECRET=change-me

# Logging
LOG_LEVEL=info
LOG_DIR=./data/logs

# Risk Overrides (use with extreme caution)
MAX_RISK_PER_TRADE_PCT=0.5
KILL_SWITCH_THRESHOLD_PCT=5
